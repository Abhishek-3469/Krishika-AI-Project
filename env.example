# Krishika AI - Agricultural AI Platform
# Environment Configuration for SIH Competition

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Krishika AI
VITE_APP_VERSION=1.0.0

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# Model Configuration
MODEL_CACHE_DIR=~/.cache/krishika-ai-models
TOKENIZERS_PARALLELISM=false

# Hugging Face Models
HF_DISEASE_MODEL=wambugu71/crop_leaf_diseases_vit
HF_SOIL_MODEL=Ben041/soil-type-classifier
HF_LANGUAGE_MODEL=ai4bharat/IndicBARTSS

# Performance Settings
MAX_FILE_SIZE=10485760  # 10MB
MODEL_TIMEOUT=30  # seconds
BATCH_SIZE=1

# Language Support
SUPPORTED_LANGUAGES=en,hi,te,ta,bn,gu,mr,or,pa,kn,ml,as
DEFAULT_LANGUAGE=en

# Offline Mode
OFFLINE_MODE=false
FALLBACK_TO_SIMULATION=true

# Competition Settings
COMPETITION_MODE=true
SHOW_ACCURACY_METRICS=true
ENABLE_VOICE_FEATURES=true
ENABLE_LANGUAGE_TRANSLATION=true
